<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0B0E24">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/proxyInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#C9CCE8"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:background="#151A3A"
            android:padding="16dp" />

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_idle"
            android:textColor="#9AA0C6"
            android:textSize="15sp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp" />

        <Button
            android:id="@+id/vpnBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/start_vpn" />

        <Button
            android:id="@+id/toggleBtn"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/start" />

        <TextView
            android:id="@+id/urlView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_link"
            android:textColor="#7B8CFF"
            android:textSize="13sp"
            android:textIsSelectable="true"
            android:background="#151A3A"
            android:padding="16dp"
            android:layout_marginTop="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/copyBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="@string/copy" />

            <Button
                android:id="@+id/openBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="@string/open_tracker" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/log_title"
                android:textColor="#9AA0C6"
                android:textSize="13sp" />

            <Button
                android:id="@+id/clearBtn"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/clear_log" />
        </LinearLayout>

        <TextView
            android:id="@+id/logView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="#8FE39A"
            android:textSize="11sp"
            android:background="#0A0C1E"
            android:padding="12dp"
            android:layout_marginTop="6dp"
            android:minHeight="180dp" />
    </LinearLayout>
</ScrollView>
