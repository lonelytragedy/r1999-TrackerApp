<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBgPage">

    <FrameLayout
        android:id="@+id/trackerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <WebView
            android:id="@+id/webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:id="@+id/webOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:background="?attr/appBgPage">

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:layout_marginBottom="20dp"
                android:scaleType="centerCrop"
                android:src="@drawable/app_logo"
                app:shapeAppearanceOverlay="@style/CircleShape" />

            <ProgressBar
                android:id="@+id/webProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminateTint="?attr/appAccent" />

            <TextView
                android:id="@+id/webTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/web_loading"
                android:textColor="?attr/appTextPrimary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/webMsg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textColor="?attr/appTextMuted"
                android:textSize="14sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/webRetry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/web_retry"
                android:visibility="gone" />
        </LinearLayout>
    </FrameLayout>

    <ScrollView
        android:id="@+id/grabberView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="96dp">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/subTabs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/subVpn"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sub_vpn" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/subProxy"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sub_proxy" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <LinearLayout
                android:id="@+id/vpnSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/vpn_hint"
                    android:textColor="?attr/appTextPrimary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:background="?attr/appBgSurface"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/vpnBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/start_vpn" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/proxySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/proxyInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/appTextPrimary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:background="?attr/appBgSurface"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/toggleBtn"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/start" />
            </LinearLayout>

            <TextView
                android:id="@+id/status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/status_idle"
                android:textColor="?attr/appTextMuted"
                android:textSize="15sp"
                android:paddingTop="18dp"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/urlView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_link"
                android:textColor="?attr/appAccent"
                android:textSize="13sp"
                android:textIsSelectable="true"
                android:background="?attr/appBgSurface"
                android:padding="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/copyBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/copy" />

                <Button
                    android:id="@+id/openBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/open_tracker" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/log_title"
                    android:textColor="?attr/appTextMuted"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/clearBtn"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/clear_log" />
            </LinearLayout>

            <TextView
                android:id="@+id/logView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="?attr/appLog"
                android:textSize="11sp"
                android:background="?attr/appLogBg"
                android:padding="12dp"
                android:layout_marginTop="6dp"
                android:minHeight="160dp" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/nav_bg"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        app:elevation="10dp"
        app:menu="@menu/bottom_nav"
        app:itemIconSize="26dp"
        app:itemIconTint="@color/nav_item"
        app:itemTextColor="@color/nav_item"
        app:labelVisibilityMode="labeled" />
</FrameLayout>
